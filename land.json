6-03-05T09:38:41Z","schema_name":"role","title":"Director of Human Resources","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-04T15:59:59Z","schema_name":"role_appointment","title":"Emily Hobbs - Director of Human Resources","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-05T09:39:55Z","schema_name":"person","title":"Emily Hobbs","web_url":"https://www.gov.uk/government/people/emily-hobbs","withdrawn":false},{"api_path":"/api/content/government/people/mark-gray","api_url":"https://www.gov.uk/api/content/government/people/mark-gray","base_path":"/government/people/mark-gray","content_id":"6580f819-8521-4276-9973-b61fb463bf63","details":{"image":{"alt_text":"Mark Gray","url":"https://assets.publishing.service.gov.uk/media/64bfcda01e10bf000e17ce0b/s465_MarkGray1.jpeg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"d81cf400-9b1e-4720-ae1a-d50aeb2952da","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2023-07-25T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"cd3be7cf-7412-430e-9b80-27cbf33b5c87","details":{"body":"\u003cp\u003eThe director is responsible for:\u003c/p\u003e\n\n\u003cul\u003e\n  \u003cli\u003eoverseeing the organisation’s transformational ambition and the programmes to deliver on this\u003c/li\u003e\n  \u003cli\u003edevelopment, operation and maintenance of new and existing technology solutions and systems\u003c/li\u003e\n  \u003cli\u003eworking across the organisation and sector to deliver service improvements for both customers and staff\u003c/li\u003e\n  \u003cli\u003eensuring the organisation’s technology is resilient and effectively underpins HMLR’s business operations\u003c/li\u003e\n  \u003cli\u003ecollaborating with and supporting colleagues to successfully embed changes\u003c/li\u003e\n\u003c/ul\u003e\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-11-08T10:15:17Z","schema_name":"role","title":"Chief Transformation \u0026 Technology Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2023-07-25T13:30:53Z","schema_name":"role_appointment","title":"Mark Gray - Chief Transformation \u0026 Technology Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2023-08-08T14:54:57Z","schema_name":"person","title":"Mark Gray","web_url":"https://www.gov.uk/government/people/mark-gray","withdrawn":false},{"api_path":"/api/content/government/people/abi-howarth","api_url":"https://www.gov.uk/api/content/government/people/abi-howarth","base_path":"/government/people/abi-howarth","content_id":"a7999a49-097c-4303-b318-95f9501d5185","details":{"image":{"alt_text":"Abi Howarth","url":"https://assets.publishing.service.gov.uk/media/67d150050c569e0d48fb09e7/s465_Abi_GOV.UK_.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"0dd60898-320a-4510-93a4-d45ea7287215","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-10-07T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"e2feb15a-d3ae-40de-bc19-c7feb6751774","details":{"body":"\u003cp\u003eThe role is accountable for driving service excellence and operational performance in the delivery of our Land Registration services over the medium to long term for the benefit of our customers.\u003c/p\u003e\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-11-06T11:47:34Z","schema_name":"role","title":"Director of Land Registration Services","withdrawn":false}]},"locale":"en","public_updated_at":"2024-10-18T10:27:27Z","schema_name":"role_appointment","title":"Abi Howarth - Director of Land Registration Services","withdrawn":false}]},"locale":"en","public_updated_at":"2024-11-06T11:48:17Z","schema_name":"person","title":"Abi Howarth","web_url":"https://www.gov.uk/government/people/abi-howarth","withdrawn":false},{"api_path":"/api/content/government/people/neil-sachdev","api_url":"https://www.gov.uk/api/content/government/people/neil-sachdev","base_path":"/government/people/neil-sachdev","content_id":"cc497436-fa76-4598-a057-763d61f96e73","details":{"image":{"alt_text":"Neil Sachdev","url":"https://assets.publishing.service.gov.uk/media/677e587e6f01ae28ab5c04c9/s465_NSachdev.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"ceca26a0-166a-4ea7-83bb-51552858315e","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2024-12-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"bbfa6e2b-04c2-4b10-8ec8-6a8b5732f282","details":{"body":"\u003cp\u003eForestry Commissioners have a number of specific statutory duties and powers, summarised in the Forestry Act as:\u003c/p\u003e\n\n\u003cul\u003e\n  \u003cli\u003epromoting the interests of forestry\u003c/li\u003e\n  \u003cli\u003ethe development of afforestation\u003c/li\u003e\n  \u003cli\u003ethe production and supply of timber and other forest products\u003c/li\u003e\n\u003c/ul\u003e\n\n\u003cp\u003eIn practice, these mainly relate to providing incentives (grants), regulation though controls on felling, plant health issues and managing the public forest estate.\u003c/p\u003e\n\n\u003cp\u003eThe Commissioners have a legal duty to seek a reasonable balance between the production and supply of timber and the interests of conservation. In promoting the multiple benefits of forestry, they also seek to take careful account of people’s needs and wishes, including local communities.\u003c/p\u003e\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-06-07T09:34:57Z","schema_name":"role","title":"Forestry Commissioner","withdrawn":false}]},"locale":"en","public_updated_at":"2025-01-08T10:48:33Z","schema_name":"role_appointmen