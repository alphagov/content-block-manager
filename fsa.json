5-02-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"822769b6-1c7e-42da-8163-7ce6f43f66b9","details":{"body":"\u003cp\u003eAs a member of the Wales Office Departmental Board, Audit and Risk Assurance Committee (ARAC) and Outcome Delivery Plan (ODP) Implementation Committee, the Non-Executive Director supports the Lead Non-Executive in ensuring the effective and successful governance of the Department by:\u003c/p\u003e\n\n\u003cul\u003e\n  \u003cli\u003eEnsuring the Departmental Board and ARAC define the vision, values, culture and strategy of the organisation and set a high standard for ethics and responsible conduct of public business.\u003c/li\u003e\n  \u003cli\u003eEnsuring the Departmental Board and ARAC maintain appropriate governance and internal controls, including ensuring sound financial, risk and performance management regimes are in place and the Department has the capacity to deliver.\u003c/li\u003e\n  \u003cli\u003eActively challenging the Board on key issues including the Business Plan and Strategic Risks.\u003c/li\u003e\n  \u003cli\u003eMonitoring the delivery of the Department’s ODP through being a member of the ODP Implementation Committee.\u003c/li\u003e\n  \u003cli\u003e\n    \u003cp\u003eEnsuring the Department’s Senior Management Team is subjected to constructive challenge in respect of the performance of the organisation; and\u003c/p\u003e\n  \u003c/li\u003e\n  \u003cli\u003eProviding counsel, advice, and support to the Secretary of State for Wales and the executive team, acting as a sounding board and “critical friend” where necessary.\u003c/li\u003e\n\u003c/ul\u003e\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-02-05T17:02:32Z","schema_name":"role","title":"Non-Executive Director for the Wales Office","withdrawn":false}]},"locale":"en","public_updated_at":"2025-02-05T16:39:03Z","schema_name":"role_appointment","title":"Dr Rhian Hayward MBE - Non-Executive Director for the Wales Office","withdrawn":false}]},"locale":"en","public_updated_at":"2025-02-05T16:36:54Z","schema_name":"person","title":"Dr Rhian Hayward MBE","web_url":"https://www.gov.uk/government/people/rhian-hayward","withdrawn":false},{"api_path":"/api/content/government/people/timothy-riley","api_url":"https://www.gov.uk/api/content/government/people/timothy-riley","base_path":"/government/people/timothy-riley","content_id":"f4356a76-23d7-4a9c-ad00-57767be2653a","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69de60f22b60817d99ff8e53/s465_Timothy_Riley.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"3a234731-2289-42bc-9a58-c0a4f7aeb2d3","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-01-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"ee8aca3a-9a8f-427f-bdb1-d8b77b40e08e","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-04-14T15:19:33Z","schema_name":"role","title":"Deputy Chair of the Food Standards Agency","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-14T15:19:00Z","schema_name":"role_appointment","title":"Timothy Riley - Food Standards Agency Board Member","withdrawn":false}]},"locale":"en","public_updated_at":"2021-08-02T12:07:08Z","schema_name":"person","title":"Timothy Riley","web_url":"https://www.gov.uk/government/people/timothy-riley","withdrawn":false},{"api_path":"/api/content/government/people/frank-atherton","api_url":"https://www.gov.uk/api/content/government/people/frank-atherton","base_path":"/government/people/frank-atherton","content_id":"0bed5762-8a3c-4f85-bba6-c84280be6990","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69ca5a30b111d64c49bb3cf6/s465_Sir_Frank_Atherton.jpg"},"privy_counsellor":false},"document_type":"person","lin