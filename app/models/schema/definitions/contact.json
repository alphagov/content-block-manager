{
  "type": "object",
  "additionalProperties": false,
  "x-embeddable-as-block": true,
  "x-field-order": ["title", "description", "contact_type"],
  "properties": {
    "addresses": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9]+(?:-[a-z0-9]+)*$": {
          "type": "object",
          "additionalProperties": false,
          "x-embeddable-as-block": true,
          "x-group": "contact_methods",
          "x-group-order": 1,
          "x-block-display-fields": ["title", "recipient", "street_address", "town_or_city", "state_or_county", "postal_code", "country", "description"],
          "x-field-order": ["title", "recipient", "street_address", "town_or_city", "state_or_county", "postal_code", "country", "description"],
          "properties": {
            "country": {
              "type": "string",
              "x-component-name": "country"
            },
             "description": {
               "type": "string",
               "x-component-name": "textarea",
               "x-govspeak-enabled": true
             },
             "postal_code": {
              "type": "string"
            },
            "recipient": {
              "type": "string"
            },
            "state_or_county": {
              "type": "string"
            },
            "street_address": {
              "type": "string",
              "x-component-name": "textarea"
            },
            "title": {
              "type": "string",
              "default": "Address"
            },
            "town_or_city": {
              "type": "string"
            }
          }
        }
      }
    },
    "contact_links": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9]+(?:-[a-z0-9]+)*$": {
          "type": "object",
          "required": ["label", "url"],
          "additionalProperties": false,
          "x-embeddable-as-block": true,
          "x-group": "contact_methods",
          "x-group-order": 4,
          "x-block-display-fields": ["url", "label", "description", "title"],
          "x-field-order": ["title", "label", "url", "description"],
          "properties": {
             "description": {
               "type": "string",
               "x-component-name": "textarea",
               "x-govspeak-enabled": true
             },
             "label": {
              "type": "string"
            },
            "title": {
              "type": "string",
              "default": "Contact link"
            },
            "url": {
              "type": "string",
              "pattern": "^(?:(?:(?:https?|ftp):)?\\/\\/)(?:\\S+(?::\\S*)?@)?(?:(?!(?:10|127)(?:\\.\\d{1,3}){3})(?!(?:169\\.254|192\\.168)(?:\\.\\d{1,3}){2})(?!172\\.(?:1[6-9]|2\\d|3[0-1])(?:\\.\\d{1,3}){2})(?:[1-9]\\d?|1\\d\\d|2[01]\\d|22[0-3])(?:\\.(?:1?\\d{1,2}|2[0-4]\\d|25[0-5])){2}(?:\\.(?:[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-4]))|(?:(?:[a-z0-9\\u00a1-\\uffff][a-z0-9\\u00a1-\\uffff_-]{0,62})?[a-z0-9\\u00a1-\\uffff]\\.)+(?:[a-z\\u00a1-\\uffff]{2,}\\.?))(?::\\d{2,5})?(?:[/?#]\\S*)?$"
            }
          }
        }
      }
    },
    "description": {
      "type": "string",
      "x-component-name": "textarea",
      "x-character-limit": 165,
      "x-govspeak-enabled": true
    },
    "email_addresses": {
      "type": "object",
      "additionalProperties": false,
      "x-embeddable-as-block": true,
      "patternProperties": {
        "^[a-z0-9]+(?:-[a-z0-9]+)*$": {
          "type": "object",
          "required": ["email_address"],
          "additionalProperties": false,
          "x-embeddable-as-block": true,
          "x-group": "contact_methods",
          "x-group-order": 2,
          "x-block-display-fields": ["title", "email_address", "subject", "body", "description"],
          "x-field-order": ["title", "label", "email_address", "subject", "body", "description"],
          "properties": {
            "body": {
              "type": "string",
              "x-component-name": "textarea"
            },
             "description": {
               "type": "string",
               "x-component-name": "textarea",
               "x-govspeak-enabled": true
             },
             "email_address": {
              "type": "string",
              "format": "email"
            },
            "subject": {
              "type": "string"
            },
            "title": {
              "type": "string",
              "default": "Email"
            }
          }
        }
      }
    },
    "order": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^addresses|contact_links|email_addresses|telephones.[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "telephones": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9]+(?:-[a-z0-9]+)*$": {
          "type": "object",
          "required": ["telephone_numbers"],
          "additionalProperties": false,
          "x-embeddable-as-block": true,
          "x-group": "contact_methods",
          "x-group-order": 3,
          "x-block-display-fields": ["title", "description", "telephone_numbers", "video_relay_service", "opening_hours", "call_charges", "bsl_guidance"],
          "x-field-order": ["title", "description", "telephone_numbers", "video_relay_service", "bsl_guidance", "opening_hours", "call_charges"],
          "properties": {
            "bsl_guidance": {
              "type": "object",
              "properties": {
                "show": {
                  "type": "boolean",
                  "default": false
                },
                "value": {
                  "type": "string",
                  "x-component-name": "textarea",
                  "x-govspeak-enabled": true,
                  "default": "British Sign Language interpreter: [use video relay service](https://connect.interpreterslive.co.uk/vrs). Provider: [InterpretersLive!](https://www.interpreterslive.co.uk/)."
                }
              }
            },
            "call_charges": {
              "type": "object",
              "else": {
                "required": []
              },
              "if": {
                "properties": {
                  "show_call_charges_info_url": {
                    "const": true
                  }
                }
              },
              "properties": {
                "call_charges_info_url": {
                  "type": "string",
                  "default": "https://gov.uk/call-charges"
                },
                "label": {
                  "type": "string",
                  "default": "Find out about call charges"
                },
                "show_call_charges_info_url": {
                  "type": "boolean",
                  "default": true
                }
              },
              "then": {
                "required": ["label", "call_charges_info_url"]
              }
            },
            "description": {
              "type": "string",
              "x-component-name": "textarea",
              "x-govspeak-enabled": true
            },
            "opening_hours": {
              "type": "object",
              "else": {
                "required": []
              },
              "if": {
                "properties": {
                  "show_opening_hours": {
                    "const": true
                  }
                }
              },
              "properties": {
                "opening_hours": {
                  "type": "string",
                  "x-component-name": "textarea",
                  "x-govspeak-enabled": true,
                  "default": "For example, 'Monday to Friday, 9am to midday and 2pm to 4:30pm (closed on [bank holidays](https://www.gov.uk/bank-holidays))' or '24-hour service'."
                },
                "show_opening_hours": {
                  "type": "boolean",
                  "default": false
                }
              },
              "then": {
                "required": ["opening_hours"]
              }
            },
            "telephone_numbers": {
              "type": "array",
              "x-component-name": "sortable_array",
              "items": {
                "type": "object",
                "required": ["label", "telephone_number"],
                "x-field-order": ["type", "label", "telephone_number"],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "telephone_number": {
                    "type": "string"
                  }
                }
              }
            },
            "title": {
              "type": "string",
              "default": "Telephone"
            },
            "video_relay_service": {
              "type": "object",
              "x-field-order": ["label", "telephone_number", "source"],
              "else": {
                "required": []
              },
              "if": {
                "properties": {
                  "show": {
                    "const": true
                  }
                }
              },
              "properties": {
                "label": {
                  "type": "string",
                  "default": "Text relay: dial 18001 then:"
                },
                "show": {
                  "type": "boolean",
                  "default": false
                },
                "source": {
                  "type": "string",
                  "x-component-name": "textarea",
                  "x-govspeak-enabled": true,
                  "default": "Provider: [Relay UK](https://www.relayuk.bt.com)"
                },
                "telephone_number": {
                  "type": "string",
                  "default": "0800 1234 1234"
                }
              },
              "then": {
                "required": ["label", "telephone_number", "source"]
              }
            }
          }
        }
      }
    }
  }
}
