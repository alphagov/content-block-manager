{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "description": {
      "type": "string",
      "x-component-name": "textarea",
      "x-character-limit": 165,
      "x-govspeak-enabled": true
    },
    "rates": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9]+(?:-[a-z0-9]+)*$": {
          "type": "object",
          "required": ["amount", "frequency"],
          "additionalProperties": false,
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^£{1}[1-9]{1,3}(,\\d{3})*(\\.\\d{2})?"
            },
             "description": {
               "type": "string",
               "x-component-name": "textarea",
               "x-govspeak-enabled": true
             },
            "frequency": {
              "type": "string",
              "enum": ["a day", "a week", "a month", "a year"]
            },
            "title": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
