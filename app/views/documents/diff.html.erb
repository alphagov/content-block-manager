<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= render "govuk_publishing_components/components/summary_list", {
      items: [
        {
          field: "Content type",
          value: @document.block_type,
        },
        {
          field: "Edition",
          value: @current_edition.title,
        },
      ],
    } %>
  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <p class="govuk-body">
      <%= link_to("Back to History and notes", "/#{ @document.id }", class: "govuk-link") %>
    </p>
  </div>
</div>