<h2 class="govuk-heading-l">Change history</h2>

<div class="timeline">
  <% domain_events.each_with_index do |domain_event, i| %>
    <%= render Document::Show::DocumentTimeline::TimelineItemComponent.new(
      domain_event:,
      schema:,
      is_first_published_version: domain_event.version&.id == first_published_version&.id,
      is_latest: i == 0,
    ) %>
  <% end %>
</div>
