<%= content_tag :div, class: "app-c-content-block-manager-array-item-component" do %>
  <% fields = capture do %>
    <% components.each do |component| %>
      <%= render component %>
    <% end %>
    <%= destroy_checkbox %>
  <% end %>
  <%= render "govuk_publishing_components/components/fieldset", {
    legend_text: label,
    heading_level: 3,
    heading_size: "m",
    classes: "app-c-content-block-manager-array-item-component__fieldset",
  } do %>

      <% unless index == 0 %>
        <%= render "govuk_publishing_components/components/button", {
          text: I18n.t("buttons.reorder.up"),
          href: move_path(index, "telephones.telephone-1[#{index}]", :up),
          name: "move_up",
          secondary_solid: false,
          data_attributes: {
            # frame_id:,
            turbo: true,
          },
          } %>
      <% end %>

    <%= fields %>
  <% end %>
<% end %>
