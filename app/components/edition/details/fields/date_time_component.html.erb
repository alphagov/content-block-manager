<legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
  <%= I18n::t("edition.titles.#{block_type}.#{field_name}") %>
</legend>

<%= render("components/datetime_fields", {
  heading_size: "s",
  field_name: field_name,
  prefix: name_prefix,
  date_heading: "Date",
  date_hint: "For example, 01 08 2025",
  time_hint: "For example, 09:30 or 19:30",
  error_items: [],
  year: {
    value: param_value("#{date_field.name}(1i)") || date_time&.year,
    id: "#{field_name}_year",
    name: field_name_for("year"),
    label: "Year",
    width: 4,
  },
  month: {
    value: param_value("#{date_field.name}(2i)") || date_time&.month,
    id: "#{field_name}_month",
    name: field_name_for("month"),
    label: "Month",
    width: 2,
  },
  day: {
    value: param_value("#{date_field.name}(3i)") || date_time&.day,
    id: "#{field_name}_day",
    name: field_name_for("day"),
    label: "Day",
    width: 2,
  },
  hour: {
    value: hour_value,
    id: "#{field_name}_hour",
    name: field_name_for("hour"),
  },
  minute: {
    value: minute_value,
    id: "#{field_name}_minute",
    name: field_name_for("minute"),
  },
}) %>
