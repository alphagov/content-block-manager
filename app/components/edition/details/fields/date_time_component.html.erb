<legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
  <%= I18n::t("edition.titles.#{block_type}.#{field_name}") %>
</legend>

<%= render("components/datetime_fields", {
  id: id,
  heading_size: "s",
  field_name: field_name,
  prefix: name_prefix,
  date_heading: "Date",
  date_hint: "For example, 01 08 2025",
  time_hint: "For example, 09:30 or 19:30",
  error_items: error_items,
  year: {
    value: date_time&.year,
    id: id_for(:year),
    name: name_for(:year),
    label: label_for(:year),
    width: 4,
  },
  month: {
    value: date_time&.month,
    id: id_for(:month),
    name: name_for(:month),
    label: label_for(:month),
    width: 2,
  },
  day: {
    value: date_time&.day,
    id: id_for(:day),
    name: name_for(:day),
    label: label_for(:day),
    width: 2,
  },
  hour: {
    value: date_time&.hour,
    id: id_for(:hour),
  },
  minute: {
    value: date_time&.min,
    id: id_for(:minute),
  },
}) %>
