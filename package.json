{
  "name": "content-block-manager",
  "description": "Create and manage re-usable blocks of content",
  "private": true,
  "author": "Government Digital Service",
  "license": "MIT",
  "scripts": {
    "lint": "yarn run lint:js && yarn run lint:prettier && yarn run lint:scss && yarn run lint:markdown",
    "lint:fix": "yarn run lint:js:fix && yarn run lint:prettier:fix && yarn run lint:scss:fix && yarn run lint:markdown:fix",
    "lint:js": "eslint --cache --cache-location .cache/eslint --color -- \"**/*.js\"",
    "lint:js:fix": "eslint --cache --cache-location .cache/eslint --color --fix -- \"**/*.js\"",
    "lint:scss": "stylelint app/assets/stylesheets/",
    "lint:scss:fix": "stylelint --fix app/assets/stylesheets/",
    "lint:markdown": "markdownlint **/*.md",
    "lint:markdown:fix": "markdownlint **/*.md -f",
    "lint:prettier": "prettier --cache --cache-location .cache/prettier --cache-strategy content --check -- \"**/*.{js,scss}\"",
    "lint:prettier:fix": "prettier --write \"**/*.{js,scss}\"",
    "jasmine:prepare": "RAILS_ENV=test bundle exec rails assets:clobber assets:precompile",
    "jasmine:ci": "yarn run jasmine:prepare && yarn run jasmine-browser-runner runSpecs",
    "jasmine:browser": "yarn run jasmine:prepare && yarn run jasmine-browser-runner",
    "links:check": "yarn run markdown-link-check --config markdown-link-check-config.json **/*.md"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "neostandard": "^0.13.0",
    "jasmine-browser-runner": "^4.0.0",
    "jasmine-core": "^6.3.0",
    "markdown-link-check": "^3.14.2",
    "markdownlint": "^0.41.0",
    "markdownlint-cli": "^0.49.0",
    "minimatch": "^10.2.5",
    "picomatch": "^4.0.4",
    "prettier": "^3.8.5",
    "stylelint": "^17.14.0",
    "stylelint-config-gds": "^3.0.0",
    "tinyglobby": "^0.2.17",
    "ts-declaration-location": "^1.0.7"
  },
  "resolutions": {
    "js-yaml": "^4.2.0"
  }
}
