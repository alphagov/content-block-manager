<% embedded_objects.keys.each do |key| %>

  <%= render FactCheck::EmbeddedMetadataDiffComponent.new(
    items: metadata_items(block, key),
    items_published: block.published_block ? metadata_items(block.published_block, key) : nil,
    schema: schema) %>

  <%= render FactCheck::EmbeddedBlockDiffComponent.new(
    items: block_items(block, key),
    items_published: block.published_block ? block_items(block.published_block, key) : nil,
    object_type:,
    object_title: key,
    document: block.document) %>

<% end %>
